# Spotify (passo 1)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# IA de extração/validação (passo 2) - defina PELO MENOS uma.
# Gemini e recomendada (contexto maior, melhor com datas). Chave gratuita em
# https://aistudio.google.com/app/apikey  (sem cartao)
GEMINI_API_KEY=
# Fallback automatico (voce ja usava na v1). Gratuito em https://console.groq.com
GROQ_API_KEY=

# Opcional: so preencha se registrar um app_id no Bandsintown (parceria).
# O endpoint publico NAO aceita app_id arbitrario.
BANDSINTOWN_APP_ID=

# Telegram (passo 3)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Spotify (passo 1)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Busca (passo 2) - RECOMENDADO: Google Custom Search (resultados reais do Google,
# 100 buscas/dia gratis, sem cartao). Sem isso, o robo cai no ddgs (cobertura pior).
#   API key:  https://console.cloud.google.com/apis/credentials  (ative "Custom Search API")
#   CSE (cx): https://programmablesearchengine.google.com  (marque "Pesquisar em toda a web")
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# IA de extracao/validacao (passo 2) - defina PELO MENOS uma.
# Gemini e recomendada. Chave gratuita (sem cartao): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Fallback automatico. Gratuito em https://console.groq.com
GROQ_API_KEY=

# Opcional: so preencha se registrar um app_id no Bandsintown (parceria).
BANDSINTOWN_APP_ID=

# Telegram (passo 3)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

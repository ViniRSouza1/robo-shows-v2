# Spotify (passo 1)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# IA + busca (passo 2). Gemini e a principal: faz busca (grounding com Google
# Search) e extracao. Chave gratuita: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Fallback de extracao no caminho ddgs. Gratuito: https://console.groq.com
GROQ_API_KEY=

# Opcional (Bandsintown, exige app_id registrado).
BANDSINTOWN_APP_ID=

# Telegram (passo 3)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
